# Non-secret runtime config only. No API keys or credentials here.
# FRED key is read from ~/keys/fred/key.txt.
# AWS credentials are read from ~/aws/keys/ (see CLAUDE.md).
# Telegram bot token is read from ~/keys/telegram/bot_token.txt.

EMAIL_FROM=
EMAIL_TO=
SES_REGION=eu-west-1
DRY_RUN=true

# Telegram bot — your personal chat ID (not a secret; just your Telegram user ID).
# Get it by running: python scripts/telegram_bot.py --get-chat-id
TELEGRAM_ALLOWED_CHAT_ID=
