# fred-macro crontab — install on EC2 with: crontab crontab.example
# Timezone: EC2 instance must be set to UTC (default). London = UTC+0 (winter) / UTC+1 (summer).
# Adjust send_daily minute/hour for BST if needed.
#
# Assumes:
#   - repo at ~/fred-macro
#   - conda at ~/miniconda3 (or ~/anaconda3; adjust CONDA_PREFIX below)
#   - env named fred-macro
#   - .env in repo root with DRY_RUN=false, EMAIL_FROM, EMAIL_TO set
#
# Test each job manually before activating cron:
#   conda activate fred-macro
#   cd ~/fred-macro && python scripts/refresh_data.py
#   cd ~/fred-macro && python scripts/run_research.py
#   cd ~/fred-macro && python scripts/send_daily.py

SHELL=/bin/bash
CONDA_PREFIX=/home/ubuntu/miniconda3
PATH=/home/ubuntu/miniconda3/envs/fred-macro/bin:/home/ubuntu/miniconda3/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
FRED_MACRO_DIR=/home/ubuntu/fred-macro

# --- Daily series refresh: 06:00 UTC daily ---
# Refreshes daily-frequency series (DGS10, DFF, SOFR, VIX, etc.).
0 6 * * * cd $FRED_MACRO_DIR && python scripts/refresh_data.py >> logs/refresh_data.log 2>&1

# --- Monthly/major-release refresh: 14:30 UTC weekdays ---
# Runs after the typical US morning release window (8:30 ET = 13:30 UTC).
# Re-runs discovery to pick up any new series from major releases.
30 14 * * 1-5 cd $FRED_MACRO_DIR && python scripts/refresh_data.py --discover >> logs/refresh_data.log 2>&1

# --- Research phase: 22:00 UTC daily ---
# After US market close. Detects new findings, enriches sources.
0 22 * * * cd $FRED_MACRO_DIR && python scripts/run_research.py && python scripts/run_research.py --enrich >> logs/run_research.log 2>&1

# --- Knowledge harvest: 23:00 UTC weekdays ---
# Scrapes FEDS Notes, Liberty Street, SF Fed for new articles and extracts findings.
# Runs after the research phase. Max 5 articles per source to stay within API budget.
0 23 * * 1-5 cd $FRED_MACRO_DIR && python scripts/run_harvest.py --max 5 >> logs/run_harvest.log 2>&1

# --- Daily email: 05:45 UTC weekdays (06:45 London winter / 06:45 London summer = 05:45 UTC) ---
# Winter (UTC+0): 05:45 UTC = 05:45 London. Adjust to 04:45 UTC in summer (BST = UTC+1).
# Simple approach: keep at 05:45 UTC year-round (arrives ~06:45 winter, ~07:45 summer — acceptable).
45 5 * * 1-5 cd $FRED_MACRO_DIR && python scripts/send_daily.py >> logs/send_daily.log 2>&1

# --- Log rotation: truncate logs weekly (Sunday 00:01 UTC) ---
1 0 * * 0 truncate -s 0 $FRED_MACRO_DIR/logs/refresh_data.log $FRED_MACRO_DIR/logs/run_research.log $FRED_MACRO_DIR/logs/send_daily.log $FRED_MACRO_DIR/logs/run_harvest.log
